{
  "$schema": "https://developers.reddit.com/schema/config-file.v1.json",
  "name": "threadstich",
  "post": {
    "dir": "dist/client",
    "entrypoints": {
      "default": {
        "inline": true,
        "entry": "splash.html"
      },
      "game": {
        "entry": "game.html"
      },
      "dashboard": {
        "entry": "dashboard.html"
      }
    }
  },
  "server": {
    "dir": "dist/server",
    "entry": "index.cjs"
  },
  "menu": {
    "items": [
      {
        "label": "Open Mod Dashboard",
        "description": "Create a community analytics dashboard post showing top topics and trending discussions.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/create-dashboard"
      },
      {
        "label": "Flush ThreadStitch Index",
        "description": "Clear the similarity index and all cached data. Run after --reset to remove stale entries.",
        "location": "subreddit",
        "forUserType": "moderator",
        "endpoint": "/internal/menu/flush-index"
      }
    ]
  },
  "triggers": {
    "onAppInstall": "/internal/triggers/on-app-install",
    "onPostSubmit": "/internal/triggers/on-post-submit",
    "onPostDelete": "/internal/triggers/on-post-delete"
  },
  "scheduler": {
    "tasks": {
      "weekly-digest": {
        "endpoint": "/internal/scheduler/weekly-digest",
        "cron": "0 9 * * 1"
      }
    }
  },
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build"
  },
  "dev": {
    "subreddit": "threadstich_dev"
  }
}